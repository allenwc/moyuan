---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}
const { title, description = "墨缘 · 小说人物关系图谱" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700&family=JetBrains+Mono&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="brand" href="/">墨缘</a>
        <nav class="nav">
          <a href="/">首页</a>
          <a href="/agent">Agent 用法</a>
          <a href="https://github.com/allenwc/moyuan" target="_blank" rel="noreferrer">GitHub</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        墨缘 Moyuan · 以关系图谱重读经典 · 数据由 CloudBase 支撑
      </div>
    </footer>
  </body>
</html>
