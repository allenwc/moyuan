# ============ CloudBase ============
# 云开发环境 ID
CLOUDBASE_ENV_ID=your-env-id
# 腾讯云 SecretId / SecretKey（需具备云开发管理权限，用于服务端执行 PG SQL）
CLOUDBASE_SECRET_ID=your-secret-id
CLOUDBASE_SECRET_KEY=your-secret-key

# ============ 自建会话鉴权 ============
# JWT 签名密钥（请使用强随机值，例如：openssl rand -hex 32）
MOYUAN_JWT_SECRET=change-me-strong-secret
# REST API 访问密钥（CLI / Agent 使用，等同 service_role 权限）
MOYUAN_API_KEY=change-me-api-key
# 是否允许开发旁路登录（true / false）
MOYUAN_ALLOW_DEV_LOGIN=false

# ============ 微信 ============
# 小程序端用 TARO_APP_WECHAT_APPID，服务端也可直接用 WECHAT_APPID
TARO_APP_WECHAT_APPID=your-wechat-appid
TARO_APP_WECHAT_SECRET=your-wechat-secret

# ============ 前端（构建期注入） ============
# REST API 基础地址；留空则使用相对路径 /api（同域部署如 Vercel 时适用）
TARO_APP_API_BASE=
# 开发期是否展示旁路登录入口
TARO_APP_DEV_BYPASS=false
