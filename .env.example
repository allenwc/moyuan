# ===== 前端（浏览器直连 Supabase，受 RLS 约束）=====
# 真实值放 .env（已被 gitignore）；这里仅作模板。
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ===== 服务端 API（仅 Vercel 服务端环境变量，绝不进前端）=====
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
MOYUAN_API_KEY=please-use-a-long-random-string

# ===== CLI / 本地调用 =====
MOYUAN_API_URL=http://localhost:3000/api
MOYUAN_API_KEY=please-use-a-long-random-string
